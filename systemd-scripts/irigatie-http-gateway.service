# /etc/systemd/system/irigatie-http-gateway.service
[Unit]
Description=Irigatie HTTP Command Gateway
After=network.target irigatie.service
Requires=irigatie.service

[Service]
Type=simple
WorkingDirectory=/home/pi/irigatie
ExecStart=/usr/bin/python3 -u /home/pi/irigatie/irigatie-http-gateway.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
