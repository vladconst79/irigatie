# /etc/systemd/system/irigatie.service
[Unit]
Description=Python Irigation Control Service
Wants=irigatie-relays-off.service
After=multi-user.target irigatie-relays-off.service

[Service]
Type=simple
WorkingDirectory=/home/pi/irigatie
ExecStart=/usr/bin/python3 -u /home/pi/irigatie/irigatie-control.py
TimeoutStopSec=20
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
